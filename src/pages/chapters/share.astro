---
import Document from '../../layouts/Document.astro';
import Annot from '../../components/Annot.astro';
import AnnotLine from '../../components/AnnotLine.astro';
import CId from '../../components/CId.astro';
import { getClaim } from '../../lib/data';
import { exactUsd, grouped } from '../../lib/format';

const acknowledged = exactUsd(getClaim('C-0013')); // $101,100,000,000
const households = grouped(134000000);             // 134,000,000
const share = '$754';                              // 101.1 bn ÷ 134 m ≈ 754 (approximate, C-0013)
---

<Document title="THE BLACK LEDGER — 04 Your Share">
  <section class="section section--first">
    <p class="chapter-title">Your share.</p>
    <p class="onramp" style="margin-top:20px">One division problem. The acknowledged secret budget, split across every American household that files a tax return.</p>
  </section>

  <!-- Formula block (spec §7.9) -->
  <section class="section">
    <div class="formula scroll-x">
      <div class="formula__row">
        <span class="formula__val">{acknowledged}</span>
        <span class="formula__note">acknowledged classified expenditure, FY2025</span>
      </div>
      <div class="formula__row">
        <span class="formula__val">÷ {households}</span>
        <span class="formula__note">U.S. households filing federal returns</span>
      </div>
      <div class="formula__row formula__row--result">
        <span class="formula__val formula__val--result">= {share}</span>
        <span class="formula__note">your household's line item, this year</span>
      </div>
    </div>
    <Annot>
      <AnnotLine>About $754 for every household that files a federal return.</AnnotLine>
      <AnnotLine>Ledger: <CId id="C-0013" /> · household count: to be registered as a Tier 1 claim at build (IRS SOI); until registered, label the result "approximate"</AnnotLine>
      <AnnotLine>This is the acknowledged portion only — before the unreported line, before the residual.</AnnotLine>
    </Annot>
  </section>

  <section class="section">
    <p class="body">You paid for a program this year. Its name, purpose, and outcome are not available to you, and by statute they do not have to be. This page states only what that arrangement costs per household, using the government's own two numbers.</p>
  </section>

</Document>
