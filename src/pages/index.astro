---
// THE BLACK LEDGER · EDITION II — THE FACE (SPEC v4 §3, §9) + THE DESCENT (v4 §4).
// The homepage is eight monuments and a footer; each monument can be sounded.
import Sounding from '../layouts/Sounding.astro';
import Mark from '../components/sounding/Mark.astro';
import Descent from '../components/sounding/Descent.astro';
import { MONUMENTS } from '../lib/sounding/monuments';
import { DESCENTS } from '../lib/sounding/descents';
import { FILES } from '../lib/sounding/files';
import { massPayload } from '../lib/mass/count';
import '../styles/descent.css';

const MASS = massPayload(); // true-count law: derived + asserted at build (v7.1 §1)

const THESIS =
  'The United States admits $101.1 billion of classified spending a year — and fails to account for twice that. Every figure on this site is traceable to its source.';
---

<Sounding title="THE BLACK LEDGER" ogImage="/og/c-0013-second.png">
  <header class="chrome">
    <a class="chrome__mark caps" href="/" aria-label="The Black Ledger — home"
      >THE BLAC<span class="wonk">K</span> LEDGER</a
    >
    <a class="chrome__record caps" href="/record">RECORD</a>
  </header>

  <h1 class="visually-hidden">THE BLACK LEDGER</h1>

  <nav class="rail" aria-hidden="true">
    {MONUMENTS.map((m) => <span class="rail__tick" data-rail={m.n}></span>)}
  </nav>

  <main class="face" id="main">
    {
      MONUMENTS.map((m, i) => (
        <section
          class="monument"
          id={m.slug}
          data-monument={m.n}
          data-citation={m.citation}
          aria-label={`Monument ${m.n}`}
        >
          <a
            class="monument__link"
            href={`#/sounding/${m.slug}`}
            data-sound={m.slug}
          >
            <figure class="monument__fig">
              <Mark kind={i + 1} />
              {!m.live && <span class="visually-hidden">{m.figure}</span>}
              <div
                class={`monument__num display num hang${m.long ? ' monument__num--long' : ''}${m.live ? ' monument__num--live' : ''}`}
                data-figure={m.figure}
                data-live={m.live ? 'true' : undefined}
                aria-hidden={m.live ? undefined : 'true'}
              >
                {m.figure}
              </div>
              <figcaption class="monument__caption">
                {m.caption}
                {m.live && <span class="monument__away caps num" data-away aria-live="polite"></span>}
                <span class="monument__ledger caps">{m.ledger}</span>
                <span class="monument__sound caps">SOUND THIS NUMBER ↓</span>
              </figcaption>
            </figure>
          </a>
        </section>
      ))
    }

    <footer class="foot">
      <section class="foot__files" aria-label="Files">
        <h2 class="caps foot__label">FILES</h2>
        <ul class="foot__list">
          {
            FILES.map((f) => (
              <li class="foot__file">
                <a class="caps" href={`/files/${f.slug}`}>
                  {f.name}
                </a>
                <span class="foot__stake">{f.stake}</span>
              </li>
            ))
          }
        </ul>
      </section>
      <p class="foot__record"><a class="caps" href="/record">RECORD</a></p>
      <p class="foot__thesis">{THESIS}</p>
      <div class="foot__device"><Mark kind="wordmark" /></div>
      <p class="foot__colophon caps">PUBLISHED AS AN OPEN AUDIT · EDITION II · MMXXVI</p>
    </footer>
  </main>

  <!-- THE DESCENT (v4 §4): overlay, one scrolled column per sounded monument -->
  <div class="sounding" id="sounding" hidden data-stratum="surface" role="dialog" aria-modal="true" aria-label="Sounding">
    <div class="sounding__col" id="sounding-col">
      {DESCENTS.map((d) => <Descent d={d} />)}
    </div>
  </div>
  <div class="sounding__head" id="sounding-head" hidden>
    <p class="sounding__fig display num" id="sounding-fig"></p>
    <button class="sounding__ascend" type="button" id="ascend">× ASCEND</button>
  </div>
  <nav class="gauge" id="gauge" aria-label="Depth" data-stratum="surface" hidden>
    <button type="button" class="gauge__tick caps" data-tick="surface">SURFACE</button>
    <button type="button" class="gauge__tick caps" data-tick="context">CONTEXT</button>
    <button type="button" class="gauge__tick caps" data-tick="method">METHOD</button>
    <button type="button" class="gauge__tick caps" data-tick="record">RECORD</button>
  </nav>
  <p class="visually-hidden" aria-live="polite" id="stratum-announce"></p>
  <span class="plumb" id="plumb" aria-hidden="true"></span>
  <script type="application/json" id="mass-data" set:html={JSON.stringify(MASS)} />
</Sounding>

<style>
  /* ---- chrome: no header menu; wordmark + RECORD only (v4 §3) ---- */
  .chrome {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 10;
    display: flex;
    justify-content: space-between;
    padding: calc(16px + env(safe-area-inset-top)) calc(20px + env(safe-area-inset-right)) 0
      calc(20px + env(safe-area-inset-left));
    pointer-events: none;
  }
  .chrome a {
    pointer-events: auto;
    font-size: 0.625rem;
    color: var(--bone-dim);
    padding: 12px;
    margin: -12px;
  }
  .chrome a:hover,
  .chrome a:focus-visible {
    color: var(--bone);
  }
  /* the single controlled quirk: the K of BLACK, Fraunces WONK 1 (v4.1 §1) */
  .wonk {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 9, 'WONK' 1;
    font-weight: 500;
    font-size: 1.15em;
    letter-spacing: 0;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
  }

  /* ---- the rail: desktop only (v4 §3) ---- */
  .rail {
    display: none;
  }
  @media (min-width: 720px) {
    .rail {
      position: fixed;
      left: calc(20px + env(safe-area-inset-left));
      top: 50%;
      transform: translateY(-50%);
      z-index: 10;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    .rail__tick {
      display: block;
      width: 14px;
      height: 1px;
      background: var(--hairline);
      transition: background 300ms;
    }
    .rail__tick.is-current {
      background: var(--ember);
    }
  }

  /* ---- the feed (v4 §1/§3) ---- */
  @media (pointer: coarse) {
    :global(html) {
      scroll-snap-type: y mandatory;
    }
    .monument {
      scroll-snap-align: start;
      scroll-snap-stop: always;
    }
    .foot {
      scroll-snap-align: end;
    }
  }

  .monument {
    min-height: 100svh;
    display: grid;
    place-items: center;
    padding: 24px calc(20px + env(safe-area-inset-right)) 24px calc(20px + env(safe-area-inset-left));
  }
  .monument__fig {
    display: grid;
    justify-items: center;
    text-align: center;
    gap: 18px;
    max-width: 100%;
  }
  .monument :global(.mark) {
    width: clamp(40px, 9vh, 64px);
    height: auto;
    color: var(--bone);
  }
  .monument__num {
    font-size: clamp(4.5rem, 22vw, 15rem); /* v4 §2 */
    letter-spacing: -0.01em;
    max-width: 100%;
  }
  .monument__num--long {
    font-size: clamp(2.25rem, 10.5vw, 8.5rem);
  }
  .monument__num--live {
    color: var(--ember);
  }
  .monument__caption {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.125rem;
    line-height: var(--leading-context);
    color: var(--bone);
    max-width: 34ch;
  }
  @media (min-width: 720px) {
    .monument__caption {
      max-width: 58ch;
    }
  }
  .monument__away {
    display: block;
    margin-top: 10px;
    font-size: 0.6875rem;
    font-style: normal;
    color: var(--bone-dim);
    min-height: 1.2em;
  }
  .monument__ledger {
    display: block;
    margin-top: 18px;
    font-size: 0.5625rem;
    font-style: normal;
    color: var(--bone-dim);
  }
  .monument__sound {
    display: block;
    margin-top: 18px;
    font-style: normal;
  }

  /* ---- footer (v4 §9) ---- */
  .foot {
    min-height: 60svh;
    display: grid;
    align-content: end;
    gap: 40px;
    padding: 64px calc(20px + env(safe-area-inset-right))
      calc(40px + env(safe-area-inset-bottom)) calc(20px + env(safe-area-inset-left));
    border-top: 1px solid var(--hairline);
  }
  .foot__label {
    font-size: 0.625rem;
    color: var(--bone-dim);
    margin-bottom: 18px;
  }
  .foot__list {
    list-style: none;
    display: grid;
    gap: 14px;
    max-width: 640px;
  }
  .foot__file {
    display: grid;
    gap: 2px;
  }
  .foot__file a {
    font-size: 0.8125rem;
    color: var(--bone);
    width: fit-content;
    padding: 6px 0;
  }
  .foot__stake {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--bone-dim);
    max-width: 58ch;
  }
  .foot__record a {
    font-size: 0.8125rem;
    color: var(--bone);
    padding: 6px 0;
  }
  .foot__thesis {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    color: var(--bone-dim);
    max-width: 58ch;
  }
  .foot__colophon {
    font-size: 0.5625rem;
    color: var(--bone-dim);
  }
  .foot__device :global(.mark) {
    width: 44px;
    height: auto;
    color: var(--bone-dim);
  }

  /* the plumb-line transition (v4.1 §3.5): the site's one page transition */
  .plumb {
    position: fixed;
    top: 0;
    left: 50%;
    width: 1px;
    height: 100vh;
    background: var(--ember);
    transform: scaleY(0);
    transform-origin: top center;
    z-index: 80;
    pointer-events: none;
  }
</style>

<script>
  import { gsap, ScrollTrigger, SplitText, reducedMotion } from '../lib/sounding/motion';
  import { getLenis } from '../lib/sounding/motion';
  import { COUNTER_RATE } from '../lib/sounding/monuments';
  import Lenis from 'lenis';

  const reduced = reducedMotion();
  const grouper = new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 });
  const usd = (n: number) => '$' + grouper.format(Math.round(n));

  /* ================= THE FACE ================= */

  const monuments = Array.from(document.querySelectorAll<HTMLElement>('.monument'));
  if (!reduced) {
    for (const el of monuments) {
      const num = el.querySelector<HTMLElement>('.monument__num');
      const caption = el.querySelector<HTMLElement>('.monument__caption');
      const mark = el.querySelector<SVGElement>('[data-mark]');
      const sound = el.querySelector<HTMLElement>('.monument__sound');
      if (!num) continue;
      const isLive = num.dataset.live === 'true';
      gsap.set(caption, { opacity: 0 });
      if (sound) gsap.set(sound, { opacity: 0 });
      if (mark) gsap.set(mark.querySelectorAll('path'), { drawSVG: '0%' });

      let arrive: () => void;
      if (isLive) {
        gsap.set(num, { y: '0.6em', opacity: 0 });
        arrive = () => {
          gsap.to(num, { y: 0, opacity: 1, duration: 0.9, ease: 'expo.out' });
        };
      } else {
        const split = new SplitText(num, { type: 'words,chars', aria: 'none' });
        gsap.set(split.chars, { y: '0.6em', opacity: 0 });
        arrive = () => {
          gsap.to(split.chars, { y: 0, opacity: 1, duration: 0.9, ease: 'expo.out', stagger: 0.02 });
          for (const ch of split.chars) {
            const target = Number(ch.textContent);
            if (!Number.isInteger(target)) continue;
            const o = { v: 0 };
            gsap.to(o, {
              v: target,
              duration: 0.9,
              ease: 'expo.out',
              snap: { v: 1 },
              onUpdate: () => {
                ch.textContent = String(Math.round(o.v));
              },
            });
          }
        };
      }

      ScrollTrigger.create({
        trigger: el,
        start: 'top 60%',
        once: true,
        onEnter: () => {
          arrive();
          if (caption) gsap.to(caption, { opacity: 1, duration: 0.5, delay: 0.15 });
          if (sound) gsap.to(sound, { opacity: 1, duration: 0.5, delay: 0.3 });
          if (mark)
            gsap.to(mark.querySelectorAll('path'), {
              drawSVG: '100%',
              duration: 1.2,
              ease: 'power1.inOut',
              stagger: 0.1,
            });
        },
      });
    }
  }

  // the feed settles monument by monument (v4 §3: one number per viewport).
  // Touch snaps via CSS; wheel momentum settles through Lenis itself.
  function lenisSnap(
    lenis: Lenis,
    getPoints: () => number[],
    getScroll: () => number
  ): (() => void) | null {
    let timer: ReturnType<typeof setTimeout> | null = null;
    let snapping = false;
    const onScroll = ({ velocity }: { velocity: number }) => {
      if (snapping) return;
      if (timer) clearTimeout(timer);
      if (Math.abs(velocity) > 0.2) return;
      timer = setTimeout(() => {
        const y = getScroll();
        const points = getPoints();
        const target = points.reduce((a, b) => (Math.abs(b - y) < Math.abs(a - y) ? b : a));
        if (Math.abs(target - y) > 6) {
          snapping = true;
          lenis.scrollTo(target, {
            duration: 0.65,
            easing: (t: number) => 1 - Math.pow(1 - t, 3),
            lock: true,
            onComplete: () => {
              snapping = false;
            },
          });
        }
      }, 140);
    };
    lenis.on('scroll', onScroll);
    return () => lenis.off('scroll', onScroll);
  }

  const mainLenis = getLenis();
  if (mainLenis && !reduced) {
    lenisSnap(
      mainLenis,
      () => {
        const max = document.documentElement.scrollHeight - window.innerHeight;
        return [...monuments.map((m) => Math.min(m.offsetTop, max)), max];
      },
      () => window.scrollY
    );
  }

  // the rail
  const ticks = new Map<string, HTMLElement>();
  document.querySelectorAll<HTMLElement>('[data-rail]').forEach((t) => ticks.set(t.dataset.rail!, t));
  let currentTick: HTMLElement | null = null;
  const io = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          const n = (e.target as HTMLElement).dataset.monument!;
          currentTick?.classList.remove('is-current');
          currentTick = ticks.get(n) ?? null;
          currentTick?.classList.add('is-current');
        }
      }
    },
    { threshold: 0.6 }
  );
  monuments.forEach((m) => io.observe(m));

  // the live counter
  const liveEl = document.querySelector<HTMLElement>('[data-live]');
  const awayEl = document.querySelector<HTMLElement>('[data-away]');
  const arrivedAt = Date.now();
  let lastShown = 0;
  const counterValue = () => COUNTER_RATE * Math.max(1, (Date.now() - arrivedAt) / 1000);
  const renderCounter = () => {
    if (liveEl) liveEl.textContent = usd(counterValue());
  };
  gsap.ticker.add(() => {
    const now = Date.now();
    if (now - lastShown >= 1000 && !document.hidden) {
      lastShown = now;
      renderCounter();
    }
  });

  // the blurred-tab title (v4.1 §3.6)
  const HOME_TITLE = document.title;
  let hiddenAt: number | null = null;
  document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
      hiddenAt = Date.now();
      document.title = 'Still counting — THE BLACK LEDGER';
    } else {
      document.title = HOME_TITLE;
      if (hiddenAt && awayEl) {
        const missed = COUNTER_RATE * ((Date.now() - hiddenAt) / 1000);
        if (missed >= 1) awayEl.textContent = `+${usd(missed)} while you were away`;
      }
      hiddenAt = null;
      renderCounter();
    }
  });

  // citation on copy (v4.1 §3.3)
  document.addEventListener('copy', (e) => {
    try {
      const sel = window.getSelection();
      if (!sel || sel.isCollapsed) return;
      const node = sel.anchorNode instanceof Element ? sel.anchorNode : sel.anchorNode?.parentElement;
      const monument = node?.closest<HTMLElement>('.monument');
      if (!monument) return;
      const num = monument.querySelector<HTMLElement>('.monument__num');
      if (!num || !sel.containsNode(num, true)) return;
      e.clipboardData?.setData('text/plain', monument.dataset.citation ?? sel.toString());
      e.preventDefault();
    } catch {
      /* graceful no-op */
    }
  });

  /* ================= THE DESCENT (v4 §4) ================= */

  const sounding = document.getElementById('sounding')!;
  const soundingCol = document.getElementById('sounding-col')!;
  const soundingHead = document.getElementById('sounding-head')!;
  const soundingFig = document.getElementById('sounding-fig')!;
  const gauge = document.getElementById('gauge')!;
  const announce = document.getElementById('stratum-announce')!;
  const ascendBtn = document.getElementById('ascend')!;
  const gaugeTicks = new Map<string, HTMLElement>();
  gauge.querySelectorAll<HTMLElement>('[data-tick]').forEach((t) => gaugeTicks.set(t.dataset.tick!, t));

  let openSlug: string | null = null;
  let pushedByUs = false;
  let lastFocus: HTMLElement | null = null;
  let overlayLenis: Lenis | null = null;
  let overlayRaf: ((t: number) => void) | null = null;
  let triggers: ScrollTrigger[] = [];
  let tweens: gsap.core.Tween[] = [];
  let currentGaugeTick: HTMLElement | null = null;
  let atBottomSince = 0;
  let exiting = false;

  function setStratum(name: string) {
    sounding.dataset.stratum = name;
    gauge.dataset.stratum = name;
    currentGaugeTick?.classList.remove('is-current');
    currentGaugeTick?.removeAttribute('aria-current');
    currentGaugeTick = gaugeTicks.get(name) ?? null;
    currentGaugeTick?.classList.add('is-current');
    currentGaugeTick?.setAttribute('aria-current', 'true');
    announce.textContent = `Stratum: ${name.toUpperCase()}`;
  }

  // the gauge tracks depth from scroll position directly — device-proof
  let strataSections: HTMLElement[] = [];
  const updateStratum = () => {
    if (!openSlug || strataSections.length === 0) return;
    const y = sounding.scrollTop + sounding.clientHeight * 0.45;
    let name = 'surface';
    for (const sec of strataSections) {
      if (sec.offsetTop <= y) name = sec.dataset.stratum!;
    }
    if (sounding.dataset.stratum !== name) setStratum(name);
  };
  sounding.addEventListener('scroll', updateStratum, { passive: true });

  // the gauge is an instrument: tapping a tick bores straight to that stratum
  gauge.querySelectorAll<HTMLButtonElement>('[data-tick]').forEach((btn) => {
    btn.addEventListener('click', () => {
      if (!openSlug) return;
      const article = document.getElementById(`descent-${openSlug}`);
      const target = article?.querySelector<HTMLElement>(`section[data-stratum="${btn.dataset.tick}"]`);
      if (!target) return;
      const top = target.offsetTop;
      if (overlayLenis) {
        overlayLenis.scrollTo(top, { duration: 0.8, easing: (t: number) => 1 - Math.pow(1 - t, 3) });
      } else {
        sounding.scrollTo({ top, behavior: reduced ? 'auto' : 'smooth' });
      }
    });
  });

  function buildTriggers(article: HTMLElement) {
    const sections = Array.from(article.querySelectorAll<HTMLElement>('[data-stratum]'));
    for (const sec of sections) {
      const body = sec.querySelector<HTMLElement>('.stratum__body, .descent__caption');
      if (body) {
        const tw = gsap.fromTo(
          body,
          { opacity: 0.15, y: 28 },
          {
            opacity: 1,
            y: 0,
            ease: 'none',
            scrollTrigger: { scroller: sounding, trigger: sec, start: 'top 85%', end: 'top 30%', scrub: 0.6 },
          }
        );
        tweens.push(tw);
        if (tw.scrollTrigger) triggers.push(tw.scrollTrigger);
      }
    }
    const fill = article.querySelector<HTMLElement>('.prop__fill');
    if (fill) {
      const tw = gsap.fromTo(
        fill,
        { scaleX: 0 },
        {
          scaleX: Number(fill.dataset.fill),
          ease: 'none',
          scrollTrigger: {
            scroller: sounding,
            trigger: fill.closest('.stratum'),
            start: 'top 70%',
            end: 'center 45%',
            scrub: 0.6,
          },
        }
      );
      tweens.push(tw);
      if (tw.scrollTrigger) triggers.push(tw.scrollTrigger);
    }
    const stamp = article.querySelector<HTMLElement>('[data-stamp]');
    if (stamp) {
      gsap.set(stamp, { opacity: 0 });
      triggers.push(
        ScrollTrigger.create({
          scroller: sounding,
          trigger: stamp,
          start: 'top 80%',
          once: true,
          onEnter: () =>
            gsap.fromTo(
              stamp,
              { scale: 1.35, opacity: 0 },
              { scale: 1, opacity: 1, duration: 0.2, ease: 'power2.out' }
            ),
        })
      );
    }
  }

  function open(slug: string, push: boolean) {
    if (openSlug === slug) return;
    if (openSlug) close(false);
    const article = document.getElementById(`descent-${slug}`);
    const monument = document.querySelector<HTMLElement>(`[data-sound="${slug}"]`);
    if (!article) return;
    openSlug = slug;
    lastFocus = (document.activeElement as HTMLElement) ?? null;
    article.hidden = false;

    const num = monument?.querySelector<HTMLElement>('.monument__num');
    soundingFig.textContent = num?.dataset.figure ?? '';

    document.documentElement.classList.add('descending');
    document.body.style.overflow = 'hidden';
    getLenis()?.stop();

    sounding.hidden = false;
    soundingHead.hidden = false;
    gauge.hidden = false;
    sounding.scrollTop = 0;
    strataSections = Array.from(article.querySelectorAll<HTMLElement>('section[data-stratum]'));
    setStratum('surface');

    if (!reduced) {
      // the takeover: FLIP-style shrink of the tapped number into the fixed header (500ms)
      gsap.fromTo(sounding, { opacity: 0 }, { opacity: 1, duration: 0.5, ease: 'power2.out' });
      if (num) {
        const from = num.getBoundingClientRect();
        gsap.set(soundingFig, { visibility: 'hidden' });
        const to = soundingFig.getBoundingClientRect();
        const ghost = num.cloneNode(true) as HTMLElement;
        ghost.className = 'sounding__ghost display num';
        ghost.style.fontSize = getComputedStyle(num).fontSize;
        document.body.appendChild(ghost);
        const gw = ghost.getBoundingClientRect();
        const scaleEnd = to.height / gw.height;
        gsap.fromTo(
          ghost,
          { x: from.left, y: from.top, scale: from.height / gw.height },
          {
            x: to.left,
            y: to.top,
            scale: scaleEnd,
            duration: 0.5,
            ease: 'expo.inOut',
            onComplete: () => {
              gsap.set(soundingFig, { visibility: 'visible' });
              ghost.remove();
            },
          }
        );
      }
      overlayLenis = new Lenis({ wrapper: sounding, content: soundingCol, autoRaf: false });
      overlayLenis.on('scroll', ScrollTrigger.update);
      overlayRaf = (time: number) => overlayLenis?.raf(time * 1000);
      gsap.ticker.add(overlayRaf);
      buildTriggers(article);
      // the borehole settles stratum by stratum
      lenisSnap(
        overlayLenis,
        () => {
          const max = sounding.scrollHeight - sounding.clientHeight;
          const secs = Array.from(article.querySelectorAll<HTMLElement>('.stratum, .below'));
          return [...secs.map((s) => Math.min(s.offsetTop, max)), max];
        },
        () => sounding.scrollTop
      );
      requestAnimationFrame(() => ScrollTrigger.refresh());
    } else {
      // reduced motion: instant cut, final states only
      article.querySelectorAll<HTMLElement>('.prop__fill').forEach((f) => {
        f.style.setProperty('--fill', f.dataset.fill ?? '0');
      });
    }

    if (push) {
      history.pushState({ sounding: slug }, '', `#/sounding/${slug}`);
      pushedByUs = true;
    }
    (ascendBtn as HTMLElement).focus();
  }

  function close(_fromHistory: boolean) {
    if (!openSlug) return;
    const article = document.getElementById(`descent-${openSlug}`);
    openSlug = null;
    strataSections = [];
    exiting = false;
    triggers.forEach((t) => t.kill());
    triggers = [];
    tweens.forEach((t) => t.kill());
    tweens = [];
    if (overlayRaf) gsap.ticker.remove(overlayRaf);
    overlayRaf = null;
    overlayLenis?.destroy();
    overlayLenis = null;
    sounding.hidden = true;
    soundingHead.hidden = true;
    gauge.hidden = true;
    if (article) article.hidden = true;
    document.documentElement.classList.remove('descending');
    document.body.style.overflow = '';
    getLenis()?.start();
    lastFocus?.focus?.();
  }

  function exitDescent() {
    if (!openSlug || exiting) return;
    exiting = true;
    const finish = () => {
      if (pushedByUs) {
        pushedByUs = false;
        history.back(); // popstate closes
      } else {
        close(false);
        history.replaceState(null, '', window.location.pathname);
      }
    };
    if (reduced) {
      finish();
    } else {
      gsap.to(sounding, { opacity: 0, duration: 0.25, ease: 'power1.in', onComplete: () => {
        finish();
        gsap.set(sounding, { opacity: 1 });
      } });
    }
  }

  // triggers: tap/click a monument or its affordance
  document.querySelectorAll<HTMLAnchorElement>('[data-sound]').forEach((a) => {
    a.addEventListener('click', (e) => {
      e.preventDefault();
      open(a.dataset.sound!, true);
    });
  });

  ascendBtn.addEventListener('click', exitDescent);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && openSlug) exitDescent();
  });

  // browser Back always works (history state per descent)
  window.addEventListener('popstate', () => {
    const m = window.location.hash.match(/^#\/sounding\/(.+)$/);
    if (m) {
      pushedByUs = false;
      open(decodeURIComponent(m[1]), false);
    } else if (openSlug) {
      close(true);
    }
  });
  // deep link: arriving on a sounding URL
  {
    const m = window.location.hash.match(/^#\/sounding\/(.+)$/);
    if (m) open(decodeURIComponent(m[1]), false);
  }

  // scroll-past-bedrock exits (rubber-band + release)
  const atBottom = () => sounding.scrollTop + sounding.clientHeight >= sounding.scrollHeight - 4;
  sounding.addEventListener(
    'scroll',
    () => {
      if (atBottom()) {
        if (!atBottomSince) atBottomSince = Date.now();
      } else {
        atBottomSince = 0;
      }
    },
    { passive: true }
  );
  const bottomIntent = () => {
    if (!openSlug || exiting) return;
    if (atBottom() && atBottomSince && Date.now() - atBottomSince > 250) {
      if (reduced) {
        exitDescent();
      } else {
        gsap.to(soundingCol, {
          y: -16,
          duration: 0.14,
          yoyo: true,
          repeat: 1,
          ease: 'power1.inOut',
          onComplete: () => {
            gsap.set(soundingCol, { y: 0 });
            exitDescent();
          },
        });
      }
    }
  };
  sounding.addEventListener('wheel', (e) => {
    if (e.deltaY > 0) bottomIntent();
  }, { passive: true });
  let touchY = 0;
  sounding.addEventListener('touchstart', (e) => {
    touchY = e.touches[0].clientY;
  }, { passive: true });
  sounding.addEventListener('touchmove', (e) => {
    if (touchY - e.touches[0].clientY > 24) bottomIntent();
  }, { passive: true });

  // the plumb-line transition (v4.1 §3.5): Face → /record only, nowhere else
  const plumb = document.getElementById('plumb');
  document.querySelectorAll<HTMLAnchorElement>('a[href="/record"]').forEach((a) => {
    a.addEventListener('click', (e) => {
      if (reduced || !plumb) return; // reduced motion: navigate plainly
      e.preventDefault();
      gsap.to(plumb, {
        scaleY: 1,
        duration: 0.45,
        ease: 'expo.inOut',
        onComplete: () => window.location.assign('/record'),
      });
    });
  });

  // TRUE COUNT · P1 keyframe harness (v7.1 §1.3): ?mass=k1|k2 renders the authored
  // keyframes on the live deployment without touching the surface. The GL module is
  // dynamically imported here and ONLY here — reduced motion / Tier C never fetch it (PF-01).
  {
    const want = new URLSearchParams(window.location.search).get('mass');
    if ((want === 'k1' || want === 'k2') && !reduced) {
      window.addEventListener('load', async () => {
        try {
          const data = JSON.parse(document.getElementById('mass-data')!.textContent!);
          const wrap = document.createElement('div');
          wrap.style.cssText = 'position:fixed;inset:0;z-index:90;background:#141210';
          const cv = document.createElement('canvas');
          cv.style.cssText = 'width:100%;height:100%;display:block';
          const cap = document.createElement('p');
          cap.className = 'monument__caption';
          cap.style.cssText =
            'position:fixed;left:50%;bottom:calc(48px + env(safe-area-inset-bottom));transform:translateX(-50%);max-width:34ch;text-align:center;margin:0;z-index:91';
          cap.textContent =
            want === 'k1'
              ? 'One hundred dollars.'
              : '$101.1 billion. Two published numbers. Nothing beneath them.';
          wrap.appendChild(cv);
          document.body.appendChild(wrap);
          document.body.appendChild(cap);
          const { mountMass } = await import('../lib/mass/scene');
          const forceWebGL = new URLSearchParams(window.location.search).get('gl') === '1';
          const mass = await mountMass(cv, data, { forceWebGL });
          mass.setKeyframe(want);
          (window as unknown as { __mass: unknown }).__mass = mass; // evidence hook (fps, backend)
        } catch (e) {
          console.log('%cRENDERER: UNAVAILABLE · TIER C HOLDS', 'font-family:monospace');
        }
      });
    }
  }

  // the Pulse (v4.1 §3.2): beats in the rail on the Face, in the gauge inside a descent
  if (!reduced) {
    setInterval(() => {
      if (document.hidden) return;
      const target = openSlug ? currentGaugeTick : currentTick;
      if (!target) return;
      gsap.fromTo(target, { scale: 1 }, { scale: 1.15, duration: 0.15, yoyo: true, repeat: 1, ease: 'power1.inOut' });
    }, 1000);
  }
</script>
