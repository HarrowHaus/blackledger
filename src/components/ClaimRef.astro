---
// Ledger annotation line for a claim (v3.1 §4):
//   "— Ledger: The acknowledged secret budget, FY2025"
// Renders the claim's plain display_name, linked to its row anchor in the register.
import { getClaim } from '../lib/data';

interface Props {
  /** claim id, e.g. "C-0013" */
  id: string;
  /** annotation key; defaults to "Ledger" */
  label?: string;
}
const { id, label = 'Ledger' } = Astro.props;
const claim = getClaim(id); // throws at build if unknown (spec §1)
---
<li>{`— ${label}: `}<a href={`/chapters/record#${claim.id}`}>{claim.displayName}</a></li>
