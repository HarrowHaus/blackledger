---
// Scroll-into-view count-up (spec §2.4 item 2): counts up once over 1.2s ease-out
// when scrolled into view. SSR renders the FINAL value, so no-JS and
// prefers-reduced-motion both show the final figure instantly (spec §8.10).
interface Props {
  value: number;
  prefix?: string;
  suffix?: string;
  decimals?: number;
  /** divide the raw value before display (e.g. 1e9 to show billions) */
  scale?: number;
  signal?: boolean;
  className?: string;
}
const { value, prefix = '', suffix = '', decimals = 0, scale = 1, signal = false, className = '' } = Astro.props;

const shown = value / scale;
const nf = new Intl.NumberFormat('en-US', { minimumFractionDigits: decimals, maximumFractionDigits: decimals });
const finalText = `${prefix}${nf.format(shown)}${suffix}`;
const cls = ['countup', signal ? 'accent' : '', className].filter(Boolean).join(' ');
---
<span
  class={cls}
  data-countup
  data-target={shown}
  data-decimals={decimals}
  data-prefix={prefix}
  data-suffix={suffix}
  style="font-variant-numeric: tabular-nums; font-feature-settings:'tnum' 1,'lnum' 1;"
>{finalText}</span>

<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const els = Array.from(document.querySelectorAll<HTMLElement>('[data-countup]'));
  if (!reduce && els.length && 'IntersectionObserver' in window) {
    const easeOut = (t: number) => 1 - Math.pow(1 - t, 3);
    const run = (el: HTMLElement) => {
      const target = parseFloat(el.dataset.target || '0');
      const decimals = parseInt(el.dataset.decimals || '0', 10);
      const prefix = el.dataset.prefix || '';
      const suffix = el.dataset.suffix || '';
      const nf = new Intl.NumberFormat('en-US', { minimumFractionDigits: decimals, maximumFractionDigits: decimals });
      const duration = 1200;
      const start = performance.now();
      const step = (now: number) => {
        const t = Math.min(1, (now - start) / duration);
        const v = easeOut(t) * target;
        el.textContent = `${prefix}${nf.format(v)}${suffix}`;
        if (t < 1) requestAnimationFrame(step);
        else el.textContent = `${prefix}${nf.format(target)}${suffix}`;
      };
      requestAnimationFrame(step);
    };
    const io = new IntersectionObserver((entries, obs) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          run(e.target as HTMLElement);
          obs.unobserve(e.target);
        }
      }
    }, { threshold: 0.6 });
    for (const el of els) io.observe(el);
  }
</script>
