---
// THE BLACK LEDGER · EDITION II — the mark system (SPEC v4 §5.1).
// One drawing system: surveyor's and boring marks. Hand-authored paths —
// every "straight" line is a shallow curve, no circle quite closes, tick
// lengths drift — the site's handwriting. Single color (--bone via
// currentColor), 1.5px stroke, no fills, animated only via DrawSVG.
interface Props {
  /** monument order 1..8, or a named device */
  kind: number | 'wordmark' | 'broken';
}
const { kind } = Astro.props;

// 1 · the plumb bob — the constant vertical reference; the second that never stops
const PLUMB = [
  'M32 5.5 C31.7 13 32.3 24 31.9 37.5',
  'M32 37.5 L26.4 45.2 L31.7 57.8 L37.3 45.6 Z',
