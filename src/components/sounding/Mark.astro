// the broken sounding line — the 404: the line paid out and lost
const BROKEN = [
  'M32 5 C31.8 11 32.2 17 32 23.5',
  'M32 31.5 C32.1 35.5 31.9 39 32 42.5',
  'M32 42.5 L26.8 49.6 L31.8 57.9 L36.9 49.9 Z',
];

const SETS: Record<string, string[]> = {
  '1': PLUMB,
  '2': CORE,
  '3': LEVEL,
  '4': RINGS,
  '5': BENCHMARK,
  '6': ROD,
  '7': LEAD,
  '8': BORE,
  wordmark: WORDMARK,
  broken: BROKEN,
};
const paths = SETS[String(kind)] ?? PLUMB;
---

<svg
  class="mark"
  viewBox="0 0 64 64"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  data-mark
>
  {paths.map((d) => <path d={d} />)}
</svg>
