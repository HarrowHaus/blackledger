---
// Live per-second counter (spec §2.4 motion item 1, §7.5, §8.8–8.10).
// Increments COUNTER_RATE ($3,206.11) per second from page load, in --signal, mono,
// tabular numerals (no layout shift). Under prefers-reduced-motion it renders a
// static value and does not tick.
import { COUNTER_RATE } from '../lib/format';

interface Props {
  label: string;
  /** figure scale (large) vs. inline */
  size?: 'figure' | 'inline';
}
const { label, size = 'figure' } = Astro.props;

// SSR seed: one second of spend, so the first paint is never $0.00.
const seed = COUNTER_RATE.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
const cls = size === 'figure' ? 'figure figure--signal counter' : 'amount counter accent';
---
<div class="label" style="margin-bottom:12px">{label}</div>
<div class={cls} data-counter data-rate={COUNTER_RATE} aria-live="off">${seed}</div>

<script>
  const rate = 3206.11;
  const fmt = (v: number) =>
    '$' + v.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const els = Array.from(document.querySelectorAll<HTMLElement>('[data-counter]'));

  if (!reduce && els.length) {
    const start = performance.now();
    const tick = () => {
      const secs = (performance.now() - start) / 1000;
      const text = fmt(secs * rate);
      for (const el of els) el.textContent = text;
    };
    tick();
    setInterval(tick, 1000); // once per second (spec §2.4)
  }
  // reduced motion: leave the SSR-seeded static value in place, no count-up.
</script>
