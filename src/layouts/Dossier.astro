---
// Dossier page template (spec §5 ch03): FILE No. label · title · [slot content:
// one large figure, annotations, 2–4 body paragraphs] · registry entries · prev/next.
import Document from './Document.astro';
import { dossierBySlug, dossierNeighbours } from '../lib/dossiers';
import { getClaim } from '../lib/data';

interface Props {
  slug: string;
  /** every claim cited in this dossier, for the "— Registry entries" list */
  cites: string[];
}
const { slug, cites } = Astro.props;
const d = dossierBySlug(slug);
const { prev, next } = dossierNeighbours(slug);
const cited = cites.map(getClaim);
---

<Document title={`THE BLACK LEDGER — 03/${d.n} ${d.name}`} hideNextChapter={true}>
  <section class="section section--first">
    <div class="label">FILE No. 03/{d.n}</div>
    <p class="chapter-title" style="margin-top:12px">{d.title}</p>
  </section>

  <slot />

  <section class="section">
    <div class="plabel">— Registry entries</div>
    <ul class="annot" style="margin-top:12px">
      {cited.map((c) => (
        <li>{'— '}<a href={`/chapters/record#${c.id}`}>{c.id}</a>{` · ${c.metric} · Tier ${c.tier}`}</li>
      ))}
    </ul>
  </section>

  <nav class="dossier-nav">
    <span>{prev ? <a href={`/chapters/subjects/${prev.slug}`}>← 03/{prev.n} {prev.name}</a> : <span></span>}</span>
    <a href="/chapters/subjects">03 — Subjects index</a>
    <span>{next ? <a href={`/chapters/subjects/${next.slug}`}>03/{next.n} {next.name} →</a> : <span></span>}</span>
  </nav>
</Document>
